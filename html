<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <title>Карта с плавной анимацией маршрута</title>
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <style>
        body { margin: 0; padding: 0; font-family: sans-serif; }
        #map { height: 80vh; width: 100%; }
        #info { padding: 10px; background-color: #eee; }
        #history { margin-top: 10px; }
    </style>
</head>
<body>
    <div id="info">
        <strong>Обновление координат каждые 10 секунд...</strong>
    </div>

    <div id="map"></div>

    <div id="history">
        <h3>История:</h3>
        <ul id="history-list"></ul>
    </div>

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        // Инициализация карты
        const map = L.map('map').setView([0, 0], 2);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            maxZoom: 18,
            attribution: '&copy; OpenStreetMap contributors'
        }).addTo(map);

        let pathData = []; // [{ lat, lng, timestamp }]
        let routeLine = null; // Линия маршрута
        let animatedMarker = null; // Анимированная точка

        // Функция получения координат с сервера
        async function fetchLocation() {
            try {
                const response = await fetch('https://localhost:5000/latest-location'); // замените на ваш URL
                if (!response.ok) throw new Error(`Ошибка получения данных: ${response.status}`);

                const data = await response.json();
                console.log("Получены данные:", data);

                // Предполагаем, что сервер теперь возвращает координаты
                if (data.latitude !== undefined && data.longitude !== undefined) {
                    // Добавляем точку с временем
                    const now = Date.now(); // если сервер не присылает timestamp
                    pathData.push({
                        lat: data.latitude,
                        lng: data.longitude,
                        timestamp: data.timestamp || now,
                        accuracy: data.accuracy || 'N/A'
                    });

                    updateAll();
                } else {
                    console.warn("Данные не содержат координат:", data);
                }
            } catch (err) {
                console.error("Ошибка при запросе:", err.message);
            }
        }

        // Обновляем всё: маршрут, историю, анимацию
        function updateAll() {
            // Обновляем маршрут
            if (routeLine) map.removeLayer(routeLine);
            if (pathData.length > 1) {
                const coords = pathData.map(p => [p.lat, p.lng]);
                routeLine = L.polyline(coords, { color: 'red', weight: 3 }).addTo(map);
                
                // Прокладываем маршрут на карте
                map.fitBounds(routeLine.getBounds());
            }

            // Добавляем в историю
            const lastPoint = pathData[pathData.length - 1];
            addToHistory(lastPoint.lat, lastPoint.lng, lastPoint.accuracy);

            // Центрируем на последней точке
            map.setView([lastPoint.lat, lastPoint.lng], 13);

            // Запускаем анимацию
            if (pathData.length > 1) {
                startSmoothAnimation();
            }
        }

        // Анимация с учётом времени
        function startSmoothAnimation() {
            if (animatedMarker) map.removeLayer(animatedMarker);
            animatedMarker = L.marker(pathData[0]).addTo(map);

            let index = 0;
            const totalDuration = pathData[pathData.length - 1].timestamp - pathData[0].timestamp;

            const moveStep = () => {
                if (index >= pathData.length) return;

                const point = pathData[index];
                animatedMarker.setLatLng([point.lat, point.lng]);

                // Вычисляем задержку до следующей точки
                if (index < pathData.length - 1) {
                    const delay = pathData[index + 1].timestamp - point.timestamp;
                    // Ускоряем в 10 раз для демонстрации, но ограничиваем минимальную задержку
                    const adjustedDelay = Math.max(delay / 10, 50);
                    setTimeout(moveStep, adjustedDelay);
                }
                index++;
            };

            moveStep();
        }

        function addToHistory(lat, lng, acc) {
            const historyList = document.getElementById('history-list');
            const li = document.createElement('li');
            li.textContent = `(${lat.toFixed(6)}, ${lng.toFixed(6)}), точность: ${acc}`;
            historyList.appendChild(li);
        }

        // Запускаем обновление каждые 10 секунд
        setInterval(fetchLocation, 10000);

        // Первый вызов
        fetchLocation();
    </script>
</body>
</html>

